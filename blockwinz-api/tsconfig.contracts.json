{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "../packages/shared/generated",
    "rootDir": "./src",
    "stripInternal": true,
    "noEmit": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*.dto.ts"]
}
