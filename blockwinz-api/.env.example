# ================================
# ENVIRONMENT SETTING
# ================================
# For development: NODE_ENV=development (or just comment out for default)
# For production: NODE_ENV=production
NODE_ENV=development
APP_URL=https://staging.blockwinz.com

# ================================
# APPLICATION SETTINGS
# ================================
APP_CONTAINER_NAME=blockwinz-api
PORT=7979
BULLBOARD_PORT=8080
CLUSTER_WORKER_NUMBER=0

# ================================
# DATABASE (PostgreSQL – Supabase or other host)
# ================================
# Use the connection string from Supabase: Project Settings → Database.
# Prefer the pooled URI (transaction mode, port 6543) for the app; use direct (5432) for migrations if needed.
# Example:
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=
#
# Optional: only if DATABASE_URL is not set (e.g. local Postgres)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_HOST=localhost
# DATABASE_PORT=5432
# POSTGRES_DB=blockwinz

# ================================
# REDIS SETTINGS (one hosted instance for local + Railway)
# ================================
# The API reads only REDIS_URL (see redisAdapter / app.module).
#
# Local dev (laptop): use Railway Redis over the public TCP proxy — same data as prod.
#   Railway → Redis service → Variables → copy the resolved REDIS_PUBLIC_URL
#   (redis://default:<password>@<RAILWAY_TCP_PROXY_DOMAIN>:<RAILWAY_TCP_PROXY_PORT>)
#
# API service on Railway: use the Redis plugin’s private URL (same DB, private network).
#   On the API service, set REDIS_URL from the Redis service (Railway “Variable Reference” to that service’s REDIS_URL).
#   or paste the private redis://default:...@<RAILWAY_PRIVATE_DOMAIN>:6379 value.
#
# Optional: redis://localhost:6379 only if REDIS_URL is unset and you run Redis in Docker.
REDIS_URL=redis://localhost:6379
REDIS_CONTAINER_NAME=redis
REDIS_PORT=6379

# ================================
# SECURITY & AUTHENTICATION
# ================================
JWT_SECRET=S3ELdxW6Q9Hu6QXWnTGg
# Used only when you run `pnpm seed` (not on app startup)
DEFAULT_ADMIN_EMAIL=ceo@blockwinz.com

# Used for encrypting/decrypting user wallet private keys
# This is a random string of characters
DATA_ENCRYPTION_KEY=S3ELdxW6Q9Hu6QXWnTGg

# ================================
# EMAIL (Mailgun)
# ================================
# API key: Mailgun Dashboard → Sending → Domain settings → API keys
MAILGUN_API_KEY=
# Sending domain (e.g. mg.yourdomain.com)
MAILGUN_DOMAIN=
# From header; must be an address on the domain above
MAILGUN_FROM=Blockwinz <noreply@mg.yourdomain.com>
# Optional: EU region — https://api.eu.mailgun.net (default US: https://api.mailgun.net)
# MAILGUN_API_URL=https://api.eu.mailgun.net

