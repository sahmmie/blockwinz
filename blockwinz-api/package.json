{
  "name": "@blockwinz/api",
  "version": "0.1.0",
  "description": "BlockWinz API",
  "author": "sahmmie",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prebuild": "pnpm --filter @blockwinz/shared build",
    "build": "nest build",
    "build:generated": "tsc -p tsconfig.contracts.json && pnpm run generated:barrel",
    "generated:barrel": "pnpm --filter @blockwinz/shared generated:barrel",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "NODE_ENV=dev && nest start --watch",
    "start:debug": "NODE_ENV=dev && nest start --debug --watch",
    "db:migrate:prod": "node dist/src/database/run-migrations.js",
    "start:prod": "node dist/src/database/run-migrations.js && NODE_ENV=production node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "update-structure": "./fr.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed": "ts-node -r tsconfig-paths/register scripts/seed.ts"
  },
  "dependencies": {
    "@2toad/profanity": "^3.1.1",
    "@blockwinz/shared": "workspace:*",
    "@bull-board/api": "^6.5.3",
    "@bull-board/express": "^6.5.3",
    "@cityofzion/neon-core": "^5.6.0",
    "@cityofzion/neon-js": "^5.6.0",
    "@nestjs-modules/ioredis": "^2.0.2",
    "@nestjs/axios": "^3.1.3",
    "@nestjs/bull": "^10.2.3",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/class-validator": "^0.13.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.0.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.0.0",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^7.3.1",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^10",
    "@socket.io/redis-adapter": "^8.3.0",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.98.0",
    "@types/crypto-js": "^4.2.2",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/lodash": "^4.17.13",
    "@types/socket.io": "^3.0.1",
    "bcrypt": "^5.1.1",
    "bignumber.js": "^9.1.2",
    "bs58": "^6.0.0",
    "bull": "^4.16.4",
    "cache-manager": "^6.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cloudinary": "^2.2.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "crypto-js": "^4.2.0",
    "csrf-csrf": "^3.1.0",
    "date-fns": "^3.6.0",
    "drizzle-orm": "^0.36.0",
    "express-basic-auth": "^1.2.1",
    "flatted": "^3.3.3",
    "form-data": "^4.0.5",
    "helmet": "^8.0.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "mailgun.js": "^12.7.1",
    "nanoid": "^3.3.7",
    "neon-js": "^1.1.2",
    "pg": "^8.13.0",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.3.1",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "drizzle-kit": "^0.28.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    },
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
