# Multiplayer (game Socket.IO namespace `/game`)
# Leave unset or `0` for live lobbies and real `newGame` / `joinGame` / `quickMatch`.
# Set to `1` only for UI work without a backend (dummy lobby list + blocked actions).
# VITE_MULTIPLAYER_LOBBY_MOCK=0

# `/lobbies` hub: when `0` or `false`, uses `listPublicLobbies` over the socket.
# In dev, omitting this defaults to static preview tables; set `0` to test live hub data locally.
# VITE_LOBBIES_HUB_STATIC=0
