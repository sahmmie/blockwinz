# Core app config
VITE_REACT_APP_SERVER_BASE_URL=http://localhost:7979
VITE_REACT_APP_TOKEN_NAME=blockwinz_token
VITE_REACT_APP_ENV=development

# Production waitlist gate: only when VITE_REACT_APP_ENV=prod AND this is set (non-empty),
# e.g. ISO date for the countdown. Omit or leave empty to serve the full app in prod.
# VITE_WAITLIST_LAUNCH_DATE=2026-06-01T00:00:00.000Z

# Optional third-party support widget
# VITE_CHATWOOT_BASE_URL=https://app.chatwoot.com
# VITE_CHATWOOT_WEBSITE_TOKEN=

# Optional monitoring sink for client-side error reports
# VITE_MONITORING_ENDPOINT=https://monitoring.example.com/intake/frontend-errors
# VITE_MONITORING_TOKEN=

# Optional PostHog Cloud analytics
# Set VITE_POSTHOG_ENABLED=true to enable analytics, feature flags, surveys, and replay.
# VITE_POSTHOG_KEY=phc_your_project_key
# VITE_POSTHOG_HOST=https://us.i.posthog.com
# VITE_POSTHOG_ENABLE_SESSION_REPLAY=false
# VITE_POSTHOG_ENABLE_SURVEYS=false
# Optional feature flag key to gate Chatwoot exposure without changing app code.
# VITE_POSTHOG_CHATWOOT_FLAG_KEY=support-chat

# Multiplayer (game Socket.IO namespace `/game`)
# Leave unset or `0` for live lobbies and real `newGame` / `joinGame` / `quickMatch`.
# Set to `1` only for UI work without a backend (dummy lobby list + blocked actions).
# VITE_MULTIPLAYER_LOBBY_MOCK=0

# `/lobbies` hub: when `0` or `false`, uses `listPublicLobbies` over the socket.
# In dev, omitting this defaults to static preview tables; set `0` to test live hub data locally.
# VITE_LOBBIES_HUB_STATIC=0
