{
  "name": "@blockwinz/shared",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./generated": {
      "types": "./generated/index.d.ts"
    }
  },
  "files": ["dist", "generated"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "generated:barrel": "node ./scripts/write-generated-barrel.mjs"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
