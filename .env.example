# Repository root — copy to `.env` for `docker compose` (API + Redis).
# PostgreSQL: set DATABASE_URL in blockwinz-api/.env (e.g. Supabase), not in Compose.
# ================================
# ENVIRONMENT SETTING
# ================================
NODE_ENV=development

# ================================
# API (NestJS)
# ================================
API_CONTAINER_NAME=blockwinz-api
API_PORT=7979
API_BULLBOARD_PORT=8080
CLUSTER_WORKER_NUMBER=0

# ================================
# REDIS
# ================================
REDIS_CONTAINER_NAME=redis
REDIS_PORT=6379

# ================================
# DOCKER COMPOSE
# ================================
MOUNT_TYPE=rw
